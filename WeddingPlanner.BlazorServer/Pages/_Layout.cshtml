@using Microsoft.AspNetCore.Components.Web
@namespace WeddingPlanner.BlazorServer.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />

    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link href="css/site.css" rel="stylesheet" />
    <link href="WeddingPlanner.BlazorServer.styles.css" rel="stylesheet" />

    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            Wystąpił błąd. Ta aplikacja może nie działać poprawnie do czasu odświeżenia.
        </environment>
        <environment include="Development">
            Wystąpił nieobsługiwany błąd. Sprawdź narzędzia deweloperskie przeglądarki.
        </environment>
        <a href="" class="reload">Odśwież</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
</body>
</html>