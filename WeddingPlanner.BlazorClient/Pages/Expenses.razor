@page "/expenses"
@using System.Net.Http.Json
@inject IJSRuntime JS
@using WeddingPlanner.Domain.Entities
@inject HttpClient Http

<PageTitle>Budżet i Wydatki</PageTitle>

<h1>Budżet i Wydatki</h1>

@if (budget != null && expenses != null)
{
    var spent = expenses.Sum(e => e.Amount);
    var remaining = budget.TotalAmount - spent;

    <div class="card mb-4 shadow-sm" style="background-color: #fdf5f6; border: 1px solid #fce4ec;">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="text-muted mb-2">Całkowity budżet</h5>
                <div class="d-flex align-items-center gap-2">
                    <input @bind="budget.TotalAmount" type="number" class="form-control" style="width: 150px;" />
                    <button class="btn" style="background-color: #5a5a5a; color: white;" @onclick="SaveBudget">Zapisz</button>
                </div>
            </div>
            <div class="text-center">
                <h5 class="text-muted mb-1">Wydano</h5>
                <h3 class="mb-0" style="color: #d81b60;">@spent.ToString("N0") zł</h3>
            </div>
            <div class="text-end">
                <h5 class="text-muted mb-1">Pozostało</h5>
                <h3 class="mb-0" style="color: @(remaining < 0 ? "red" : "#2e7d32");">@remaining.ToString("N0") zł</h3>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card p-3 shadow-sm h-100" style="border: 1px solid #eceff1; background-color: #fff;">
                <h5 class="text-muted mb-3">Wydatki wg kategorii</h5>
                @foreach (var group in expenses.GroupBy(e => e.Category).OrderByDescending(g => g.Sum(e => e.Amount)))
                {
                    var groupSum = group.Sum(e => e.Amount);
                    var percent = spent > 0 ? (groupSum / spent) * 100 : 0;
                    <div class="mb-2">
                        <div class="d-flex justify-content-between" style="font-size: 0.9rem;">
                            <span>@group.Key</span>
                            <strong>@groupSum.ToString("N0") zł</strong>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar" style="width: @((int)percent)%; background-color: #d1a3a4;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3 shadow-sm h-100" style="border: 1px solid #eceff1; background-color: #fff;">
                <h5 class="text-muted mb-3">Status płatności</h5>
                @{
                    var paid = expenses.Where(e => e.IsPaid).Sum(e => e.Amount);
                    var unpaid = spent - paid;
                }
                <div class="d-flex justify-content-between" style="font-size: 0.9rem;">
                    <span>Opłacone: @paid.ToString("N0") zł</span>
                    <span>Do zapłaty: @unpaid.ToString("N0") zł</span>
                </div>
                <div class="progress mt-2" style="height: 20px;">
                    <div class="progress-bar" style="width: @(spent > 0 ? (int)((paid / spent) * 100) : 0)%; background-color: #a3b899;"></div>
                    <div class="progress-bar" style="width: @(spent > 0 ? (int)((unpaid / spent) * 100) : 0)%; background-color: #d49a9a;"></div>
                </div>
            </div>
        </div>
    </div>
}

<div class="mb-4 p-3 border rounded shadow-sm bg-white">
    <h3>Dodaj wydatek</h3>
    <EditForm Model="newExpense" OnValidSubmit="AddExpense">
        <DataAnnotationsValidator />
        <div class="d-flex gap-2 align-items-start flex-wrap">
            <div style="flex-grow: 1;">
                <InputText @bind-Value="newExpense.Name" class="form-control" placeholder="Nazwa wydatku" />
            </div>
            <div style="width: 120px;">
                <InputNumber @bind-Value="newExpense.Amount" class="form-control" placeholder="Kwota" />
            </div>
            <div style="width: 200px;">
                <InputSelect @bind-Value="newExpense.Category" class="form-select">
                    <option value="Sala i jedzenie">Sala i jedzenie</option>
                    <option value="Ubiór">Ubiór</option>
                    <option value="Usługi">Usługi</option>
                    <option value="Dekoracje">Dekoracje</option>
                    <option value="Inne">Inne</option>
                </InputSelect>
            </div>
            <button type="submit" class="btn" style="background-color: #5a5a5a; color: white;">Dodaj</button>
        </div>
    </EditForm>
</div>

<table class="table align-middle table-hover shadow-sm bg-white">
    <thead style="background-color: #f8f9fa;">
        <tr>
            <th>Nazwa</th>
            <th>Kategoria</th>
            <th>Kwota</th>
            <th>Status</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @if (expenses != null)
        {
            @foreach (var exp in expenses)
            {
                <tr>
                    <td>
                        @if (editingExpenseId == exp.Id)
                        {
                            <InputText @bind-Value="exp.Name" class="form-control form-control-sm" />
                        }
                        else
                        {
                            <strong>@exp.Name</strong>
                        }
                    </td>
                    <td>
                        @if (editingExpenseId == exp.Id)
                        {
                            <InputSelect @bind-Value="exp.Category" class="form-select form-select-sm">
                                <option value="Sala i jedzenie">Sala i jedzenie</option>
                                <option value="Ubiór">Ubiór</option>
                                <option value="Usługi">Usługi</option>
                                <option value="Dekoracje">Dekoracje</option>
                                <option value="Inne">Inne</option>
                            </InputSelect>
                        }
                        else
                        {
                            <span class="badge" style="background-color: #eee; color: #333;">@exp.Category</span>
                        }
                    </td>
                    <td>
                        @if (editingExpenseId == exp.Id)
                        {
                            <InputNumber @bind-Value="exp.Amount" class="form-control form-control-sm" />
                        }
                        else
                        {
                            @exp.Amount.ToString("N0")
                            @(" zł")
                        }
                    </td>
                    <td style="cursor: pointer; font-size: 1.5rem;" @onclick="() => TogglePaid(exp)">
                        @(exp.IsPaid ? "✅" : "❌")
                    </td>
                    <td>
                        @if (editingExpenseId == exp.Id)
                        {
                            <button class="btn btn-sm btn-success" @onclick="() => SaveExpense(exp)">💾</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => editingExpenseId = exp.Id">✏️</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteExpense(exp)">🗑️</button>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
@code {
    private Expense[]? expenses;
    private WeddingBudget? budget;
    private Expense newExpense = new() { Category = "Inne" };
    private int? editingExpenseId;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        expenses = await Http.GetFromJsonAsync<Expense[]>("api/Expenses");
        budget = await Http.GetFromJsonAsync<WeddingBudget>("api/Budgets");
    }

    private async Task SaveBudget() => await Http.PutAsJsonAsync("api/Budgets", budget);

    private async Task AddExpense()
    {

        await Http.PostAsJsonAsync("api/Expenses", newExpense);
        newExpense = new() { Category = "Inne" }; 
        await LoadData();
    }

    private async Task TogglePaid(Expense exp)
    {
        exp.IsPaid = !exp.IsPaid;
        await Http.PutAsJsonAsync($"api/Expenses/{exp.Id}", exp);
    }

    private async Task DeleteExpense(int id)
    {
        await Http.DeleteAsync($"api/Expenses/{id}");
        await LoadData();
    }

    private async Task SaveExpense(Expense exp)
    {
        await Http.PutAsJsonAsync($"api/Expenses/{exp.Id}", exp);
        editingExpenseId = null;
        await LoadData();
    }

    private async Task DeleteExpense(Expense exp)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Czy na pewno chcesz usunąć wydatek: '{exp.Name}'?");
        if (confirmed)
        {
            await Http.DeleteAsync($"api/Expenses/{exp.Id}");
            await LoadData();
        }
    }
}
}